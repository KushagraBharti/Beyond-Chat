    "exa-js": "^2.10.1",
    "gray-matter": "^4.0.3",
    "linkedom": "^0.18.12",
    "playwright": "^1.58.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/bun": "latest",
