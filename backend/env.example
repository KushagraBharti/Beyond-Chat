# Canonical backend variable-name template. An ignored backend/.env or
# backend/.env.local is noncanonical machine-local state; validate names only and
# verify Supabase identity against canonical project ref vffndfwdykxqjlnntuuk.

# Core deployment URL
APP_URL=http://127.0.0.1:5173

# AI providers. An API key alone is insufficient: policy limits must also be set.
OPENROUTER_API_KEY=
OPENROUTER_MODEL_ALLOWLIST=
OPENROUTER_MAX_COMPLETION_TOKENS=0
OPENROUTER_MAX_REQUEST_COST_CENTS=0
OPENROUTER_TIMEOUT_SECONDS=45
EXASEARCH_API_KEY=
EXASEARCH_TIMEOUT_SECONDS=30

# Finance data
FINANCIAL_DATASETS_API_KEY=

# Social data, optional
X_BEARER_TOKEN=

# Dexter sandbox runner
DEXTER_RUNNER_URL=
DEXTER_RUNNER_SHARED_SECRET=

# Stripe billing (disabled unless BILLING_V2_ENABLED=true)
BILLING_V2_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_BILLING_V2_WEBHOOK_SECRET=
STRIPE_BILLING_V2_PRICE_ID=

# Compatibility aliases used only by the legacy billing routes. Do not set both
# a canonical key and its alias in the same environment.
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRO_PRICE_ID=

# Google integrations, optional
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/integrations/google-calendar/callback

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WorkOS AuthKit (backend only; use a high-entropy cookie password of at least 32 characters)
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_COOKIE_PASSWORD=
WORKOS_REDIRECT_URI=http://127.0.0.1:8000/api/auth/callback
WORKOS_LOGOUT_URI=http://127.0.0.1:5173
WORKOS_WEBHOOK_SECRET=
WORKOS_ISSUER=https://api.workos.com/user_management/client_REPLACE_ME
WORKOS_SESSION_COOKIE_NAME=beyond_session
WORKOS_STATE_COOKIE_NAME=beyond_auth_state
WORKOS_CSRF_COOKIE_NAME=beyond_csrf

# Composio stays unavailable until an HTTPS callback, auth-config allowlist, and
# exact promoted read/write tool versions are configured.
COMPOSIO_API_KEY=
COMPOSIO_AUTH_CONFIG_ALLOWLIST_JSON={}
COMPOSIO_READ_TOOL_VERSIONS_JSON={}
COMPOSIO_WRITE_TOOL_VERSIONS_JSON={}
COMPOSIO_CALLBACK_URL=
COMPOSIO_TIMEOUT_SECONDS=30
