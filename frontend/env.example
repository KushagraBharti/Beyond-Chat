# Legacy Supabase credentials are retained only for explicitly isolated prototype adapters.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Canonical WorkOS sessions are HttpOnly backend cookies; no WorkOS secret belongs here.
# Change this only when WORKOS_CSRF_COOKIE_NAME is changed on the backend.
VITE_WORKOS_CSRF_COOKIE_NAME=beyond_csrf

# Vercel server-side rewrite target. Browser requests remain same-origin at /api/*.
API_BASE_URL=http://127.0.0.1:8000
