# Canonical repository-level operator variable-name template only.
# Application variables are documented in scripts/config/environment-manifest.json
# and projected into backend/env.example and frontend/env.example.
# Any ignored local .env file is a noncanonical machine-local projection. Do not
# infer provider identity from it or copy it between services.

# Modal CLI credentials are local operator credentials. Never inject them into a sandbox.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
