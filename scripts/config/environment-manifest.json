{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schemaVersion": 1,
  "environments": ["local", "preview", "production"],
  "surfaces": ["root", "backend", "frontend", "sandbox-runner", "modal-control-plane"],
  "requirementValues": ["required", "conditional", "optional", "managed", "forbidden"],
  "featureGates": {
    "core_urls": { "local": true, "preview": true, "production": true },
    "supabase_data": { "local": true, "preview": true, "production": true },
    "workos_auth": { "local": true, "preview": true, "production": true },
    "legacy_supabase_browser": { "local": false, "preview": false, "production": false },
    "live_models": { "local": false, "preview": false, "production": false },
    "research_search": { "local": false, "preview": false, "production": false },
    "finance_data": { "local": false, "preview": false, "production": false },
    "social_search": { "local": false, "preview": false, "production": false },
    "google_calendar": { "local": false, "preview": false, "production": false },
    "legacy_dexter_runner": { "local": false, "preview": false, "production": false },
    "modal_execution": { "local": false, "preview": false, "production": false },
    "composio_actions": { "local": false, "preview": false, "production": false },
    "billing_v2": { "local": false, "preview": false, "production": false },
    "legacy_billing": { "local": false, "preview": false, "production": false }
  },
  "providerManagedPatterns": ["^VERCEL$", "^VERCEL_", "^CI$", "^GITHUB_", "^SUPABASE_AUTH_"],
