    { "name": "SUPABASE_URL", "type": "url", "owner": "data", "provider": "Supabase", "sensitivity": "public", "surfaces": ["backend"], "featureGate": "supabase_data", "environments": { "local": "required", "preview": "required", "production": "required" } },
    { "name": "SUPABASE_ANON_KEY", "type": "token", "owner": "data", "provider": "Supabase", "sensitivity": "public", "surfaces": ["backend"], "featureGate": "legacy_supabase_browser", "environments": { "local": "conditional", "preview": "conditional", "production": "conditional" } },
